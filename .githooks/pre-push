#!/bin/sh
# The Doorman — pre-push hook
# Check 1: Oath — "I never push to main."
# Check 2: Branch naming — type/issue-NUMBER-description

# ── Check 1: Oath ─────────────────────────────────────────────────────────────
# No exceptions. Not even automation branches. Main is sacred.
while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -q "refs/heads/main$"; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║              The Doorman — Access Denied                 ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║                                                          ║"
    echo "║  Direct push to 'main' is forbidden by the Oath.        ║"
    echo "║                                                          ║"
    echo "║  > I never push to main.                                 ║"
    echo "║                                                          ║"
    echo "║  Open a pull request. The Society is watching.           ║"
    echo "║                                                          ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
done

# ── Check 2: Issue number in branch name ──────────────────────────────────────
# Expected: type/issue-NUMBER-description (e.g., fix/issue-135-members-registry)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

ISSUE_NUMBER=$(echo "$BRANCH" | grep -oE 'issue-[0-9]+' | grep -oE '[0-9]+')

if [ -z "$ISSUE_NUMBER" ]; then
  echo ""
  echo "┌────────────────────────────────────────────────────────────────┐"
  echo "│ The Society requires a ticket before pushing.                 │"
  echo "├────────────────────────────────────────────────────────────────┤"
  echo "│ Branch name must match: type/issue-NUMBER-description          │"
  echo "│                                                                │"
  echo "│ Examples:                                                      │"
  echo "│   fix/issue-135-members-registry                              │"
  echo "│   feat/issue-136-skill-md-migration                           │"
  echo "│                                                                │"
  echo "│ Create an issue first:                                        │"
  echo "│   gh issue create --title \"...\"                              │"
  echo "│                                                                │"
  echo "│ Then rename your branch:                                      │"
  echo "│   git branch -m type/issue-NUMBER-description                │"
  echo "└────────────────────────────────────────────────────────────────┘"
  echo ""
  exit 1
fi

# ── Check: Issue exists (non-blocking, requires gh CLI) ───────────────────────
if command -v gh >/dev/null 2>&1; then
  if ! gh issue view "$ISSUE_NUMBER" --json state > /dev/null 2>&1; then
    echo ""
    echo "┌────────────────────────────────────────────────────────────────┐"
    echo "│ Issue #$ISSUE_NUMBER does not exist.                              │"
    echo "├────────────────────────────────────────────────────────────────┤"
    echo "│ Create it:                                                     │"
    echo "│   gh issue create --title \"...\"                              │"
    echo "└────────────────────────────────────────────────────────────────┘"
    echo ""
    echo "  To ignore, push with --no-verify."
    exit 1
  fi
fi

exit 0