{
  "name": "agenthood",
  "version": "1.2.3",
  "description": "A society of AI agents with impeccable standards and zero tolerance for 'fix stuff' commits.",
  "keywords": [
    "ai-agents",
    "developer-experience",
    "conventional-commits",
    "commitlint",
    "husky",
    "semantic-release",
    "claude-code",
    "agent-skills",
    "dx",
    "git-workflow"
  ],
  "homepage": "https://github.com/fworks-tech/agenthood#readme",
  "bugs": {
    "url": "https://github.com/fworks-tech/agenthood/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fworks-tech/agenthood.git"
  },
  "license": "MIT",
  "author": "Fabio Ritzel Borges <fritzelborges@gmail.com>",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "agenthood": "./dist/cli.js"
  },
  "files": [
    "dist",
    "members",
    "conventions",
    "portals",
    "rituals",
    "agentic-workflows",
    "workflows",
    "architecture",
    "INITIATION.md",
    "oath.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node -e \"const{existsSync}=require('fs');if(existsSync('dist/cli.js')){require('child_process').execSync('node dist/cli.js setup',{stdio:'inherit'})}\"",
    "test": "vitest run --exclude 'vscode-extension/**'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "semantic-release": "^24.2.9",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
