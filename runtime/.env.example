# Required: Anthropic API key for all member LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Required for installed-package scenarios: absolute path to the agenthood repo root
# so SkillsPathResolver can locate members/*.md files.
# If running from within the agenthood repo, this is set automatically.
AGENTHOOD_ROOT=/path/to/agenthood

# Optional: LangSmith tracing (recommended for debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agenthood-runtime
