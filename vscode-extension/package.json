{
  "name": "agenthood-vscode",
  "displayName": "Agenthood",
  "description": "A society of AI agents with impeccable standards and zero tolerance for 'fix stuff' commits.",
  "version": "0.1.0",
  "publisher": "fworks-tech",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters",
    "SCM Providers"
  ],
  "keywords": [
    "agenthood",
    "conventional-commits",
    "commitlint",
    "ai-agents",
    "developer-experience"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fworks-tech/agenthood.git"
  },
  "activationEvents": [
    "workspaceContains:.gitmessage",
    "workspaceContains:commitlint.config.cjs"
  ],
  "main": "./dist/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "agenthood.init",
        "title": "Agenthood: Initiate the Society"
      },
      {
        "command": "agenthood.check",
        "title": "Agenthood: Run Health Check"
      },
      {
        "command": "agenthood.oath",
        "title": "Agenthood: Read the Oath"
      },
      {
        "command": "agenthood.activate",
        "title": "Agenthood: Activate a Member"
      },
      {
        "command": "agenthood.deactivate",
        "title": "Agenthood: Deactivate a Member"
      },
      {
        "command": "agenthood.list",
        "title": "Agenthood: List Members"
      }
    ],
    "configuration": {
      "title": "Agenthood",
      "properties": {
        "agenthood.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Agenthood extension"
        },
        "agenthood.statusBar.show": {
          "type": "boolean",
          "default": true,
          "description": "Show active member count in the status bar"
        },
        "agenthood.commitValidation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Validate commit messages inline as you type in the SCM input"
        },
        "agenthood.rituals.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show ritual notifications (morning briefing, health check, watchman alerts)"
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "agenthood.check",
          "group": "agenthood"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "mocha": "^10.4.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.6.3"
  }
}
